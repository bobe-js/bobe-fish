{
  "name": "bobe-fish",
  "displayName": "Bobe Fish",
  "description": "A Dark purple Theme for Visual Studio Code",
  "version": "1.0.11",
  "publisher": "smooth-cat",
  "license": "MIT",
  "keywords": [
    "theme",
    "dark",
    "bobe",
    "fish"
  ],
  "icon": "icon.png",
  "homepage": "https://github.com/bobe-js/bobe-fish",
  "repository": {
    "url": "https://github.com/bobe-js/bobe-fish",
    "type": "git"
  },
  "bugs": {
    "url": "https://github.com/bobe-js/bobe-fish/issues"
  },
  "galleryBanner": {
    "color": "#1f2335",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.17.0"
  },
  "categories": [
    "Themes",
    "Other"
  ],
  "contributes": {
    "themes": [
      {
        "label": "Bobe Fish Black",
        "uiTheme": "vs-dark",
        "path": "./themes/bobe-fish-black-color-theme.json"
      },
      {
        "label": "Bobe Fish Purple",
        "uiTheme": "vs-dark",
        "path": "./themes/bobe-fish-color-theme.json"
      },
      {
        "label": "Bobe Fish Black High Contrast",
        "uiTheme": "vs-dark",
        "path": "./themes/bobe-fish-black-high-contrast-color-theme.json"
      },
      {
        "label": "Bobe Fish Blue",
        "uiTheme": "vs-dark",
        "path": "./themes/bobe-fish-lagoon-color-theme.json"
      }
    ]
  },
  "scripts": {
    "log": "vsce login",
    "setup": "cd node_modules/bun && node install.js",
    "ver": "bun scripts/update-version.ts",
    "build:themes": "bun scripts/build-themes.ts",
    "build": "bun scripts/build-themes.ts && vsce package",
    "pub": "bun scripts/build-themes.ts && vsce publish"
  },
  "devDependencies": {
    "vsce": "^2.15.0"
  }
}
